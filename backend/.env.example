# AccOps 环境变量配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env

# ── 数据库 ──
GAM_DATABASE_URL=postgresql://postgres:your_password@127.0.0.1:5432/gam

# ── JWT 签名密钥 (生产环境请使用随机字符串) ──
GAM_SECRET_KEY=change-me-to-a-random-string

# ── Google OAuth (Antigravity / Cloud Code 客户端) ──
GAM_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GAM_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# ── 服务配置 (可选) ──
# GAM_HOST=127.0.0.1
# GAM_PORT=17893
# GAM_CORS_ORIGINS=http://localhost:17894,http://127.0.0.1:17894
# GAM_TOKEN_EXPIRE_MINUTES=480
